{
  "manifest_version": 3,
  "name": "Screenshot Pro",
  "version": "2.0",
  "description": "Captura en WebP máxima calidad. Botón flotante visible en pantalla completa. Bypass anti-screenshot.",
  "permissions": [
    "tabs",
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "take-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Tomar screenshot"
    }
  }
}